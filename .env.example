# =============================================================================
# .env.example — Template for environment variables
#
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in real values in .env
#   3. NEVER commit .env — it is in .gitignore for a reason.
#
# ENVIRONMENTS:
#   - Local dev:  .env file on your machine (read by dotenv in server.js)
#   - Staging:    GitHub Secret MONGO_URI_STAGING / JWT_SECRET_STAGING
#                 injected into the Kubernetes Secret by the CD workflow
#   - Production: GitHub Secret MONGO_URI_PROD / JWT_SECRET_PROD
#                 injected into the Kubernetes Secret by the CD workflow
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
# Port the Express server listens on.
# In Kubernetes this is overridden by the container spec; 3000 is for local dev.
PORT=3000

# Controls Express behaviour:
#   development — enables morgan logging, includes stack traces in error responses
#   production  — disables logging, hides stack traces (set by Dockerfile ENV layer)
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB connection string.
#
# Local dev (docker-compose): mongodb://devuser:devpassword@localhost:27017/simple_crud_dev?authSource=admin
# MongoDB Atlas:              mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
#
# Use separate Atlas clusters (or at least separate databases) for each environment:
#   dev:     simple_crud_dev
#   staging: simple_crud_staging
#   prod:    simple_crud_prod
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── Authentication ────────────────────────────────────────────────────────────
# Secret key used to sign and verify JWT tokens.
# REQUIREMENTS:
#   - Minimum 32 characters
#   - Random, high-entropy string (generate with: openssl rand -hex 64)
#   - DIFFERENT for each environment (leaking staging secret != leaking prod secret)
JWT_SECRET=replace-this-with-a-long-random-string-at-least-32-chars

# How long issued tokens stay valid before the user must log in again.
# Examples: 7d (7 days), 24h (24 hours), 15m (15 minutes)
JWT_EXPIRES_IN=7d

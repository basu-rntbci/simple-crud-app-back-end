# ── Node.js ───────────────────────────────────────────────────────────────────
node_modules
npm-debug.log*

# ── Environment & Secrets ─────────────────────────────────────────────────────
# NEVER commit .env files — they contain database passwords and JWT secrets.
# Use .env.example as the committed template; each developer fills in their own.
.env
.env.*
!.env.example

# ── Build output ──────────────────────────────────────────────────────────────
coverage
frontend/dist

# ── Kubernetes Secrets ────────────────────────────────────────────────────────
# Secret YAML files containing real credentials must never be committed.
# Use the k8s/secrets/*.template.yaml files as templates instead.
k8s/secrets/*.yaml
!k8s/secrets/*.template.yaml

# ── OS & IDE ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ── Claude Code ───────────────────────────────────────────────────────────────
.claude/
